@startuml
skinparam shadowing false
skinparam defaultFontName Arial
skinparam activity {
    BackgroundColor White
    BorderColor #2F3542
    FontColor #1E1E2F
}
skinparam ArrowColor #000000

start

:Запуск программы;
:Создание объекта Sudoku;

:Очистка solution[9][9];
:Запуск генерации полного поля\nfillBoard(0, 0);

while (Полное поле сгенерировано?) is (Нет)
    :Выбор пустой клетки;
    :Перемешивание чисел 1..9;

    if (Можно поставить число?) then (Да)
        :Поставить число в клетку;
        :Переход к следующей клетке;
    else (Нет)
        :Откат назад\nBacktracking;
    endif
endwhile (Да)

:Копирование solution[9][9]\nв field[9][9];

while (Удалено нужное количество клеток?) is (Нет)
    :Случайный выбор клетки;
    :Временное удаление числа;
    :Подсчет количества решений\ncountSolutions();

    if (Решение единственное?) then (Да)
        :Оставить клетку пустой;
    else (Нет)
        :Вернуть число обратно;
    endif
endwhile (Да)

:Пометить начальные клетки\nfixedCells[9][9];
:Вывод игрового поля;

while (Игра завершена?) is (Нет)
    :Ввод строки, столбца и числа;

    if (Введено 0 0 0?) then (Да)
        :Выход из игры;
        stop
    else (Нет)
    endif

    if (Координаты корректны?) then (Да)
        if (Клетка не является начальной?) then (Да)
            if (Клетка пустая?) then (Да)
                if (Число не нарушает правила Судоку?) then (Да)
                    :Записать число в field[9][9];
                    :Сообщение "Ход сделан";
                else (Нет)
                    :Сообщение "Такой ход невозможен";
                endif
            else (Нет)
                :Сообщение "Клетка уже заполнена";
            endif
        else (Нет)
            :Сообщение "Начальную клетку менять нельзя";
        endif
    else (Нет)
        :Сообщение "Некорректные координаты";
    endif

    :Вывод игрового поля;

    if (Поле полностью заполнено?) then (Да)
        if (field[9][9] совпадает\nс solution[9][9]?) then (Да)
            :Поздравление с победой;
            stop
        else (Нет)
            :Сообщение об ошибке;
        endif
    else (Нет)
    endif

endwhile

stop
@enduml