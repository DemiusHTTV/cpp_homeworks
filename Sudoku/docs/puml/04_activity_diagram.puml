@startuml
skinparam shadowing false
skinparam defaultFontName Arial
skinparam activity {
    BackgroundColor White
    BorderColor #2F3542
    FontColor #1E1E2F
}
skinparam ArrowColor #000000

start

:Запуск программы;
:Создание объекта GameManager;
:Создание SudokuBoard и SudokuGenerator;

:Очистка поля;
:Запуск генерации полного решения;

while (Полное поле сгенерировано?) is (Нет)
    :Выбор пустой клетки;
    :Перемешивание чисел 1..9;

    if (Можно поставить число?) then (Да)
        :Поставить число;
        :Перейти к следующей клетке;
    else (Нет)
        :Откат назад\nBacktracking;
    endif
endwhile (Да)

:Копирование solution[9][9]\nв field[9][9];

while (Удалено нужное\nколичество клеток?) is (Нет)
    :Случайный выбор клетки;
    :Временное удаление числа;
    :Подсчет количества решений;

    if (Решение единственное?) then (Да)
        :Оставить клетку пустой;
    else (Нет)
        :Вернуть число обратно;
    endif
endwhile (Да)

:Пометить начальные клетки\nfixedCells[9][9];
:Вывод игрового поля;

while (Судоку решено?) is (Нет)
    :Ввод строки, столбца и числа;

    if (Введено 0 0 0?) then (Да)
        :Выход из игры;
        stop
    else (Нет)
    endif

    if (Значение равно 0?) then (Да)
        if (Клетка не начальная?) then (Да)
            :Очистить клетку;
        else (Нет)
            :Сообщение об ошибке;
        endif
    else (Нет)
        if (Координаты и число корректны?) then (Да)
            if (Клетка свободна и не начальная?) then (Да)
                if (Число не нарушает правила?) then (Да)
                    :Записать число в field[9][9];
                    :Сообщение "Ход сделан";
                else (Нет)
                    :Сообщение "Такой ход невозможен";
                endif
            else (Нет)
                :Сообщение "Клетку нельзя изменить";
            endif
        else (Нет)
            :Сообщение "Некорректный ввод";
        endif
    endif

    :Вывод игрового поля;
endwhile (Да)

:Поздравление с победой;
stop
@enduml
