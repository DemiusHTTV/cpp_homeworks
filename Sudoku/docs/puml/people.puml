@startuml

actor "Игрок" as Player
participant "main()" as Main
participant "Sudoku" as Sudoku

Player -> Main : Вводит строку, столбец и число
Main -> Sudoku : makeMove(row, col, value)

Sudoku -> Sudoku : Проверка границ
Sudoku -> Sudoku : Проверка fixedCells
Sudoku -> Sudoku : canPlaceInBoard()

alt Ход корректный
    Sudoku --> Main : true
    Main --> Player : Ход сделан
else Ход некорректный
    Sudoku --> Main : false
    Main --> Player : Такой ход невозможен
end

@enduml