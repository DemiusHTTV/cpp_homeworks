@startuml
skinparam shadowing false
skinparam defaultFontName Arial
skinparam rectangle {
    RoundCorner 10
}

rectangle "main.cpp" as Main #E3F2FD
rectangle "GameManager.h / .cpp" as GameManager #E8F5E9
rectangle "SudokuBoard.h / .cpp" as Board #FFF3E0
rectangle "SudokuGenerator.h / .cpp" as Generator #FFF3E0
rectangle "SudokuSolver.h / .cpp" as Solver #FFF3E0
rectangle "Игрок" as Player #F3E5F5

database "field[9][9]\nsolution[9][9]\nfixedCells[9][9]" as Data #ECEFF1

Main --> GameManager : создает и запускает
GameManager --> Player : получает ввод
GameManager --> Board : управляет полем
GameManager --> Generator : запускает генерацию
Generator --> Board : заполняет и очищает клетки
Generator --> Solver : проверяет уникальность
Solver --> Board : использует правила Судоку
Board --> Data : хранит состояние игры

@enduml
