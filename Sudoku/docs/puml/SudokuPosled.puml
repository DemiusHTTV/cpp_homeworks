@startuml
skinparam shadowing false
skinparam defaultFontName Arial

start

:Очистить поле solution;
:Запустить fillBoard(0, 0);

while (Есть пустая клетка?) is (Да)
    :Перемешать числа от 1 до 9;

    repeat
        :Взять следующее число;

        if (Можно поставить число?) then (Да)
            :Поставить число;
            :Перейти к следующей клетке;

            if (Дальше поле заполняется?) then (Да)
                break
            else (Нет)
                :Откатить число;
            endif
        else (Нет)
        endif

    repeat while (Остались числа?) is (Да)

    if (Нет подходящего числа?) then (Да)
        :Вернуться назад\nbacktracking;
    endif
endwhile (Нет)

:Скопировать solution в field;
:Случайно выбрать клетку;
:Удалить число;
:Посчитать количество решений;

if (Решение единственное?) then (Да)
    :Оставить клетку пустой;
else (Нет)
    :Вернуть число обратно;
endif

:Повторять до нужного\nколичества удаленных клеток;

stop
@enduml